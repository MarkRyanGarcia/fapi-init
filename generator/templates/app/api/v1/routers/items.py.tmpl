from fastapi import APIRouter, Depends
{{- if .UseFastCRUD }}
from sqlmodel import Session
from app.db.session import get_db
from app.schemas.item import ItemCreate, ItemCreateInternal, ItemRead
from app.services.item_service import crud_items
{{- else if .UseSQLModel }}
from sqlmodel import Session
from app.db.session import get_db
from app.schemas.item import ItemCreate, ItemRead
from app.services.item_service import ItemService
{{- else if .IncludeSQLAlchemy }}
from sqlalchemy.orm import Session
from app.db.session import get_db
from app.schemas.item import ItemCreate, ItemRead
from app.services.item_service import ItemService
{{- else if .IncludeMongoDB }}
from pymongo.database import Database
from app.db.session import get_db
from app.schemas.item import ItemCreate, ItemRead
from app.services.item_service import ItemService
{{- else }}
from app.schemas.item import ItemCreate, ItemRead
from app.services.item_service import ItemService
{{- end }}
{{- if or .UseClerk .UseCognito }}
from app.core.security import require_auth, get_optional_auth_id
{{- end }}

router = APIRouter()

{{- if .UseFastCRUD }}
@router.get("", response_model=list[ItemRead])
async def list_items(
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
):
    result = await crud_items.get_multi(db)
    return result["data"]

@router.post("", response_model=ItemRead)
async def create_item(
    item: ItemCreate,
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
):
    return await crud_items.create(db, ItemCreateInternal(**item.model_dump()))
{{- else if or .UseSQLModel .IncludeSQLAlchemy }}
@router.get("", response_model=list[ItemRead])
def list_items(
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
):
    return ItemService.get_all(db)

@router.post("", response_model=ItemRead)
def create_item(
    item: ItemCreate,
    db: Session = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
):
    return ItemService.create(db, item)
{{- else if .IncludeMongoDB }}
@router.get("", response_model=list[ItemRead])
def list_items(
    db: Database = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
):
    return ItemService.get_all(db)

@router.post("", response_model=ItemRead)
def create_item(
    item: ItemCreate,
    db: Database = Depends(get_db),
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
):
    return ItemService.create(db, item)
{{- else }}
@router.get("", response_model=list[ItemRead])
async def list_items(
{{- if or .UseClerk .UseCognito }}
    user_id: str | None = Depends(get_optional_auth_id),
{{- end }}
):
    return await ItemService.get_all()

@router.post("", response_model=ItemRead)
async def create_item(
    item: ItemCreate,
{{- if or .UseClerk .UseCognito }}
    user_id: str = Depends(require_auth),
{{- end }}
):
    return await ItemService.create(item)
{{- end }}
