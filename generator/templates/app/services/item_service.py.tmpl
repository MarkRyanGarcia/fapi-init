{{- if .UseFastCRUD }}
from fastcrud import FastCRUD
from app.models.item import Item
from app.schemas.item import (
    ItemCreateInternal,
    ItemUpdate,
    ItemUpdateInternal,
    ItemDelete,
    ItemRead,
)

CRUDItem = FastCRUD[
    Item,
    ItemCreateInternal,
    ItemUpdate,
    ItemUpdateInternal,
    ItemDelete,
    ItemRead,
]
crud_items = CRUDItem(Item)
{{- else if .UseSQLModel }}
from sqlmodel import Session, select
from app.models.item import Item
from app.schemas.item import ItemCreate

class ItemService:
    @staticmethod
    def get_all(db: Session) -> list[Item]:
        return db.exec(select(Item)).all()

    @staticmethod
    def create(db: Session, item: ItemCreate) -> Item:
        db_item = Item(**item.model_dump())
        db.add(db_item)
        db.commit()
        db.refresh(db_item)
        return db_item
{{- else if .IncludeSQLAlchemy }}
from sqlalchemy.orm import Session
from app.models.item import Item
from app.schemas.item import ItemCreate

class ItemService:
    @staticmethod
    def get_all(db: Session) -> list[Item]:
        return db.query(Item).all()

    @staticmethod
    def create(db: Session, item: ItemCreate) -> Item:
        db_item = Item(**item.model_dump())
        db.add(db_item)
        db.commit()
        db.refresh(db_item)
        return db_item
{{- else if .IncludeMongoDB }}
from pymongo.database import Database
from app.models.item import Item
from app.schemas.item import ItemCreate

class ItemService:
    @staticmethod
    def get_all(db: Database) -> list[Item]:
        docs = db["items"].find()
        return [Item(id=str(d["_id"]), title=d["title"], owner_id=d["owner_id"]) for d in docs]

    @staticmethod
    def create(db: Database, item: ItemCreate) -> Item:
        doc = item.model_dump()
        result = db["items"].insert_one(doc)
        doc["id"] = str(result.inserted_id)
        return Item(**{k: v for k, v in doc.items() if k != "_id"})
{{- else }}
